{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default",
  "remote": {
    "urls": [
      "http://localhost:3000/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-progress-bar",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-internal-toggle-maximize",
    "opener:default",
    "process:default",
    "updater:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" }
      ]
    }
  ]
}
